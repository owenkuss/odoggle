# Local dev: Next.js proxies /api/backend/* to the game server (no CORS setup needed).
API_PROXY_TARGET=http://localhost:3001

# Production (Vercel): point at your Fly.io server instead of using the proxy.
# NEXT_PUBLIC_API_URL=https://YOUR-APP.fly.dev
# NEXT_PUBLIC_WS_URL=wss://YOUR-APP.fly.dev/signal
# NEXT_PUBLIC_URL=https://odoggle.com

CREEM_API_KEY=
CREEM_PRODUCT_ID=
CREEM_WEBHOOK_SECRET=
